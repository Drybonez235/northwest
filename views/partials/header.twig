<header class="bg-white border-b border-neutral-100 font-sans sticky top-0 z-50">
  <div class="container mx-auto px-4 flex items-center justify-between h-20">
    
     {# Logo and Church Name Wrapper #}
      <div class="flex items-center gap-4">
        <div class="site-logo">
            {% if custom_logo_url %}
                <a href="{{ site.url }}">
                    <img src="{{ custom_logo_url }}" alt="{{ theme.name }}" class="h-12 w-auto">
                </a>
            {% else %}
                <h1 class="text-xl/7 font-bold">
                    <a href="{{ site.url }}">{{ theme.name }}</a>
                </h1>
            {% endif %}
        </div>

        <h2 class="text-lg/6 font-semibold text-gray-800">
            {{ theme.name }}
        </h2>
    </div>

    {# Desktop Navigation #}
    <nav class="hidden md:flex items-center gap-8">

      {# Dynamic Ministries Dropdown #}
      <div class="group relative py-4">
        <button class="flex items-center gap-1 text-sm font-bold uppercase tracking-wider text-neutral-700 group-hover:text-primary-600 transition-colors cursor-pointer">
          {{ lang == 'es' ? 'Ministerios' : 'Ministries' }}
          <svg class="size-4 opacity-40 group-hover:rotate-180 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        {# Dropdown Menu #}
        <div class="absolute top-full right-0 w-64 bg-white shadow-sm border border-neutral-100 rounded-church py-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
          {% for ministry in nav_ministries %}
            <a href="{{ ministry.link }}" class="block px-6 py-2.5 hover:bg-neutral-50 group/item">
              <span class="block text-sm font-bold text-neutral-800 group-hover/item:text-primary-600">
                {# Uses Title Name meta, falls back to Post Title #}
                {{ ministry.meta('_ministry_title_name') ?: ministry.title }}
              </span>
            </a>
          {% endfor %}
          
        </div>
      </div>
      {# Regular Posts Dropdown #}
  <div class="group relative flex items-center h-full">
    <button class="flex items-center gap-1 text-sm font-bold uppercase tracking-wider text-neutral-700 group-hover:text-primary-600 transition-colors cursor-pointer">
      {{ lang == 'es' ? 'Sobre Nosotros' : 'About Us' }}
      <svg class="size-4 opacity-40 group-hover:rotate-180 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path d="M19 9l-7 7-7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    {# Dropdown Menu - Aligned Right to stay on screen #}
    <div class="absolute top-full right-0 w-72 bg-white shadow-md border border-neutral-100 rounded-church py-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-">
      {% for post in nav_posts %}
        <a href="{{ post.link }}" class="block px-6 py-3 hover:bg-neutral-50 group/item transition-colors">
          <span class="block text-sm/5 font-bold text-neutral-800 group-hover/item:text-primary-600">
            {{ post.title }}
          </span>
        </a>
      {% endfor %}
    </nav>
  </div>
</header>