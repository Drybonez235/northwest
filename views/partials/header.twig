<header class="bg-slate-50 flex flex-col md:flex-row items-center justify-between p-4 lg:p-6 border-b border-black/10">
    
    {# Logo and Church Name Wrapper #}
    <div class="flex items-center gap-4">
        <div class="site-logo">
            {% if custom_logo_url %}
                <a href="{{ site.url }}">
                    <img src="{{ custom_logo_url }}" alt="{{ theme.name }}" class="h-12 w-auto">
                </a>
            {% else %}
                <h1 class="text-xl/7 font-bold">
                    <a href="{{ site.url }}">{{ theme.name }}</a>
                </h1>
            {% endif %}
        </div>

        <h2 class="text-lg/6 font-semibold text-gray-800">
            {{ theme.name }}
        </h2>
    </div>

    {# Primary Navigation #}
    <nav class="mt-4 md:mt-0">
        <ul class="flex gap-6 list-none">
            {#% for item in menu.items % 
                <li class="{{ item.classes | join(' ') }}">
                    <a href="{{ item.link }}" class="text-base/6 font-medium !text-gray-800 !hover:text-black transition-all hover:scale-110 ">
                        {{ item.title }}
                    </a>
                </li>
            {% endfor %} #}
           {# Dynamic Ministries Dropdown #}
      <div class="group relative py-4">
        <button class="flex items-center gap-1 text-sm font-bold uppercase tracking-wider text-neutral-700 group-hover:text-primary-600 transition-colors cursor-pointer">
          {{ lang == 'es' ? 'Ministerios' : 'Ministries' }}
          <svg class="size-4 opacity-40 group-hover:rotate-180 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        {# Dropdown Menu #}
        <div class="absolute top-full left-0 w-64 bg-white shadow-sm border border-neutral-100 rounded-church py-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
          {% for ministry in nav_ministries %}
            <a href="{{ ministry.link }}" class="block px-6 py-2.5 hover:bg-neutral-50 group/item">
              <span class="block text-sm font-bold text-neutral-800 group-hover/item:text-primary-600">
                {# Uses Title Name meta, falls back to Post Title #}
                {{ ministry.meta('_ministry_title_name') ?: ministry.title }}
              </span>
              {% if ministry.meta('_ministry_caption') %}
                <span class="block text-xs/4 text-neutral-500">{{ ministry.meta('_ministry_caption') }}</span>
              {% endif %}
            </a>
          {% endfor %}
          
          {# "View All" Link #}
          <div class="border-t border-neutral-50 mt-2 pt-2 px-6">
            <a href="/ministries" class="text-xs font-black uppercase tracking-widest text-gold-700 hover:text-primary-600">
              {{ lang == 'es' ? 'Ver Todos' : 'View All' }} &rarr;
            </a>
          </div>
        </div>
        </ul>
    </nav>

</header>