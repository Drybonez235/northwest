{% extends "base.twig" %}

{% block content %}

{# views/index.twig #}
{# No layouts yet, just raw HTML to test #}
<div style="background: #f0f0f0; padding: 50px; text-align: center; font-family: sans-serif;">
    <h1 style="color: #2563eb;">Timber is officially connected!</h1>
    <p>Site Name: {{ site.name }}</p>
    
    <div style="margin-top: 20px; border: 2px dashed #ccc; padding: 20px;">
        <h2>Custom Field Test:</h2>
        <p>Sermon Title: <strong>{{ post.meta('sermon_title') }}</strong></p>
        <p>Preacher: <strong>{{ post.meta('preacher_name') }}</strong></p>
    </div>
</div>
{# views/index.twig #}


{% block content %}
    <div class="container mx-auto mt-8">
        {% include "partials/sermon-hero.twig" %}
        
        {# The rest of your Gutenberg content #}
        <article class="prose max-w-none mx-auto py-10">
            {{ post.content }}
        </article>
    </div>
{% endblock %}