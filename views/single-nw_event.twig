{# single-nw_event.twig #}
{% extends "base.twig" %}

{% block content %}
<article class="bg-neutral-50 min-h-dvh py-12 lg:py-22">
    <main class="max-w-container-3xl mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-18 items-start">
            
            {# Left Column: Content #}
            <div class="flex flex-col">
                <header class="mb-8">
                    <h1 class="font-display text-4xl font-bold text-neutral-900 mb-2">
                        {{ post.meta('nw_event_title') }}
                    </h1>
                    <p class="text-xl/7 text-primary-600 font-semibold">
                        {{ post.meta('nw_event_subtitle') }}
                    </p>
                </header>

                {# Logistics: Date, Time, Location #}
                <div class="flex flex-col gap-1 mb-8 text-neutral-600 font-medium">
                    <div class="text-lg/6">
                        {{ post.meta('nw_event_date')|date("F j, Y") }}
                    </div>
                    <div class="text-base">
                        {{ post.meta('nw_event_time') }}
                    </div>
                    <div class="text-base italic">
                        {{ post.meta('nw_event_location') }}
                    </div>
                </div>

                {# Event Description #}
                <div class="prose prose-neutral max-w-none mb-10">
                    {{ post.meta('nw_event_description') }}
                </div>

                {# Call to Action #}
                {% if post.meta('nw_event_cta_url') %}
                    <div>
                        <a href="{{ post.meta('nw_event_cta_url') }}" 
                           class="inline-block bg-primary-500 hover:bg-primary-600 text-white px-8 py-4 rounded-church font-bold transition-colors shadow-sm">
                            {{ post.meta('nw_event_cta_text') }}
                        </a>
                    </div>
                {% endif %}
            </div>

            {# Right Column: Image #}
            <div class="relative">
                {% if post.meta('nw_event_bg_url') %}
                    <div class="aspect-square overflow-hidden rounded-church shadow-md">
                        <img src="{{ post.meta('nw_event_bg_url') }}" 
                             class="size-full object-cover" 
                             alt="{{ post.meta('nw_event_title') }}">
                    </div>
                {% endif %}
                
                {# Language Toggle (Subtle) #}
                {% if post.meta('nw_event_bilingual') %}
                    <div class="flex gap-4 mt-6 justify-end">
                        <a href="{{ post.meta('nw_event_english_url') }}" class="text-xs font-bold uppercase tracking-widest text-neutral-400 hover:text-primary-500 transition-colors">English</a>
                        <span class="text-neutral-200">/</span>
                        <a href="{{ post.meta('nw_event_spanish_url') }}" class="text-xs font-bold uppercase tracking-widest text-neutral-400 hover:text-primary-500 transition-colors">Español</a>
                    </div>
                {% endif %}
            </div>

        </div>
    </main>
</article>
{% endblock %}