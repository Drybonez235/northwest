{# single-ministry.twig #}
{% extends "base.twig" %}

{# single-nw_event.twig #}
<article class="bg-neutral-50 min-h-dvh">
    {# Hero Section using the Custom Background URL #}
    <header class="relative h-96 bg-neutral-900 overflow-hidden">
        <img src="{{ post.meta('nw_event_bg_url') }}" class="absolute inset-0 size-full object-cover opacity-60" alt="">
        <div class="relative z-10 flex flex-col items-center justify-center h-full text-white text-center px-4">
            <h1 class="font-display text-4xl font-bold text-shadow-lg">{{ post.meta('nw_event_title') }}</h1>
            <p class="text-xl/7 mt-2">{{ post.meta('nw_event_subtitle') }}</p>
        </div>
    </header>

    <main class="max-w-container-3xl mx-auto px-4 py-12 gap-12 flex flex-col lg:flex-row">
        <div class="lg:w-2/3">
            <div class="prose prose-neutral">
                {{ post.meta('nw_event_description') }}
            </div>
        </div>

        <aside class="lg:w-1/3 bg-white p-6 shadow-sm rounded-church border border-neutral-200">
            <div class="flex flex-col gap-4">
                <div class="flex items-center gap-3">
                    <span class="font-bold text-primary-600">Date:</span>
                    <span>{{ post.meta('nw_event_date')|date("F j, Y") }}</span>
                </div>
                <div class="flex items-center gap-3">
                    <span class="font-bold text-primary-600">Time:</span>
                    <span>{{ post.meta('nw_event_time') }}</span>
                </div>
                <div class="flex items-center gap-3 border-b border-neutral-100 pb-4">
                    <span class="font-bold text-primary-600">Location:</span>
                    <span>{{ post.meta('nw_event_location') }}</span>
                </div>

                <a href="{{ post.meta('nw_event_cta_url') }}" 
                   class="bg-primary-500 hover:bg-primary-600 text-white text-center py-3 rounded-sm font-bold transition-colors">
                    {{ post.meta('nw_event_cta_text') }}
                </a>

                {% if post.meta('nw_event_bilingual') %}
                    <div class="flex gap-2 mt-4">
                        <a href="{{ post.meta('nw_event_english_url') }}" class="text-xs font-bold uppercase tracking-wider text-neutral-500 hover:text-primary-500">English</a>
                        <span class="text-neutral-300">|</span>
                        <a href="{{ post.meta('nw_event_spanish_url') }}" class="text-xs font-bold uppercase tracking-wider text-neutral-500 hover:text-primary-500">Español</a>
                    </div>
                {% endif %}
            </div>
        </aside>
    </main>
</article>
{% endblock %}