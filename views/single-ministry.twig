{# single-ministry.twig #}
{% extends "base.twig" %}

{% block content %}
<article class="min-h-dvh bg-neutral-50 font-sans px-10">
  
  {# --- Section 1: Intro & Leader (Two Columns) --- #}
  <section class="mx-auto max-w-container-3xl px-4 py-12 md:py-18 lg:py-22">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-18 items-center">
      
      {# Left Column: Title, Subheading, Description #}
      <div class="lg:col-span-8 order-2 lg:order-1">
       {# 2. Use the custom Title Name instead of standard title if provided #}
<h1 class="font-display text-4xl md:text-6xl text-primary-600 uppercase tracking-tight mb-4">
  {{ post.meta('_ministry_title_name') ?: post.title }}
</h1>
        
        {% if post.meta('_ministry_caption') %}
          <p class="text-xl/8 md:text-2xl/9 text-neutral-500 font-medium mb-8">
            {{ post.meta('_ministry_caption') }}
          </p>
        {% endif %}

        <div class="text-neutral-700 text-base/7 md:text-lg/8 whitespace-pre-wrap">
          {{ post.meta('_ministry_description') }}
        </div>
      </div>

      {# Right Column: Leader Photo & Name #}
      <div class="lg:col-span-4 order-1 lg:order-2 flex flex-col items-center text-center">
        {% if post.meta('_ministry_leader_photo') %}
          <div class="size-64 md:size-80 mb-6">
            <img 
              src="{{ post.meta('_ministry_leader_photo') }}" 
              alt="{{ post.meta('_ministry_leader_name') }}" 
              class="size-full object-cover rounded-church shadow-xl border-b-4 border-gold-500"
            >
          </div>
        {% endif %}
        
        <h3 class="font-display text-2xl text-neutral-900 uppercase tracking-wide">
          {{ post.meta('_ministry_leader_name') }}
        </h3>
        <p class="text-neutral-500 font-bold uppercase tracking-widest text-xs mt-2">{{'_ministry_title_nametitle_name}}</p>
      </div>

    </div>
  </section>

  {# --- Section 2: Image & Involvement (Alternated) --- #}
  <section class="bg-white border-y border-neutral-200">
    <div class="mx-auto max-w-container-3xl px-4 py-12 md:py-18 lg:py-22">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-18 items-center">
        
        {# Left Column: Hero Image #}
        <div class="lg:col-span-6">
          {% if post.meta('_ministry_hero_image') %}
            <div class="aspect-video lg:aspect-square overflow-hidden rounded-church shadow-2xl">
              <img 
                src="{{ post.meta('_ministry_hero_image') }}" 
                alt="{{ post.meta('_ministry_hero_desc') }}" 
                class="size-full object-cover hover:scale-105 transition-transform duration-700"
              >
            </div>
          {% endif %}
        </div>

        {# Right Column: How to get involved #}
        <div class="lg:col-span-6">
          <div class="bg-primary-50 p-8 md:p-12 rounded-church">
            <h2 class="font-display text-3xl md:text-4xl text-primary-800 mb-6 uppercase">
              {{ post.meta('_ministry_involved_head') ?: 'How to Get Involved' }}
            </h2>
            <div class="text-neutral-800 text-base/7 md:text-lg/8 mb-8">
              {{ post.meta('_ministry_involved_text') }}
            </div>
            
            {# 3. Updated CTA Button in the "Involved" section #}
{% if post.meta('_ministry_cta_url') %}
    <a href="{{ post.meta('_ministry_cta_url') }}" class="inline-block bg-primary-600 hover:bg-primary-700 text-white font-bold py-4 px-10 rounded-church transition-all hover:shadow-lg uppercase text-sm tracking-widest">
        {{ post.meta('_ministry_cta_text') ?: (post.meta('_ministry_en_es') == 'ES' ? 'Empezar Hoy' : 'Get Started Today') }}
    </a>
{% endif %}
          </div>
        </div>

      </div>
    </div>
  </section>

</article>
{% endblock %}